{
  "name": "kept",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "VITE_E2E=1 vite",
    "seed:e2e": "npx tsx e2e/seed.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "verify": "tsc --noEmit && eslint src/ && vitest run",
    "lint": "eslint src/",
    "e2e:pilot": "bash e2e/pilot/run.sh",
    "dev:pilot": "cargo tauri dev",
    "check": "tsc --noEmit && eslint src/ --max-warnings 0 && vitest run && node node_modules/vite/bin/vite.js build",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@fabianlars/tauri-plugin-oauth": "^2.0.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "2.4.0",
    "dompurify": "^3.4.7",
    "lucide-static": "^1.17.0",
    "tauri-plugin-keyring-api": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/browser": "^4.1.7",
    "better-sqlite3": "^12.10.0",
    "eslint": "^10.4.1",
    "happy-dom": "^20.9.0",
    "simple-git-hooks": "^2.13.1",
    "sql.js": "^1.14.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.14",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.7"
  },
  "simple-git-hooks": {
    "pre-push": "npm run check"
  }
}
