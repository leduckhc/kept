{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kept",
  "version": "0.1.0",
  "identifier": "com.kept.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kept",
        "width": 1100,
        "height": 750,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.googleapis.com https://accounts.google.com https://oauth2.googleapis.com https://www.google.com http://127.0.0.1:*; img-src 'self' https://www.google.com data:; font-src 'self';"
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:kept.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
