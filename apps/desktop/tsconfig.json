{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@kept/ui": ["../../packages/ui/src/index.js"],
      "@kept/search-core": ["../../packages/search-core/src/index.js"],
      "@kept/ai-core": ["../../packages/ai-core/src/index.js"],
      "@kept/mail-core": ["../../packages/mail-core/src/index.js"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/ui" },
    { "path": "../../packages/search-core" },
    { "path": "../../packages/ai-core" },
    { "path": "../../packages/mail-core" }
  ],
  "exclude": ["node_modules", "dist"]
}
