{
  "name": "kept",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "kept",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {}
    },
    "apps/desktop": {
      "name": "@kept/desktop",
      "version": "0.1.0"
    },
    "node_modules/@kept/ai-core": {
      "resolved": "packages/ai-core",
      "link": true
    },
    "node_modules/@kept/desktop": {
      "resolved": "apps/desktop",
      "link": true
    },
    "node_modules/@kept/mail-core": {
      "resolved": "packages/mail-core",
      "link": true
    },
    "node_modules/@kept/search-core": {
      "resolved": "packages/search-core",
      "link": true
    },
    "node_modules/@kept/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "packages/ai-core": {
      "name": "@kept/ai-core",
      "version": "0.1.0"
    },
    "packages/mail-core": {
      "name": "@kept/mail-core",
      "version": "0.1.0"
    },
    "packages/search-core": {
      "name": "@kept/search-core",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@kept/ui",
      "version": "0.1.0"
    }
  }
}
